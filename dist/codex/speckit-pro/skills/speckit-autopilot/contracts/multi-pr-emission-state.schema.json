{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRSG-009/PRSG-013 multi_pr_emission state",
  "type": "object",
  "required": ["schema_version", "status", "base_branch", "base_sha", "next_slice_id", "reconciled_at", "slices"],
  "anyOf": [
    { "required": ["source_layer_plan"] },
    { "required": ["source_marker_plan", "marker_split_result"] }
  ],
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "status": { "type": "string", "enum": ["pending", "emitting", "blocked", "complete"] },
    "emission_mode": { "type": "string", "enum": ["layer", "marker"] },
    "route": { "type": "string", "enum": ["layer_plan", "marker_split", "hazard_collapsed"] },
    "source_layer_plan": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha": { "type": "string" },
        "generated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "source_marker_plan": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha": { "type": "string" },
        "generated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "marker_split_result": {
      "type": "object",
      "required": ["path"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "sha": { "type": "string" },
        "generated_at": { "type": "string" }
      },
      "additionalProperties": false
    },
    "base_branch": { "type": "string", "minLength": 1 },
    "base_sha": { "type": "string", "minLength": 1 },
    "next_slice_id": { "type": ["string", "null"] },
    "reconciled_at": { "type": "string" },
    "slices": {
      "type": "array",
      "items": { "$ref": "#/definitions/slice" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/definitions/warning" }
    },
    "failed_slice": { "$ref": "#/definitions/failure" }
  },
  "additionalProperties": false,
  "definitions": {
    "slice": {
      "type": "object",
      "required": ["slice_id", "review_order", "expected_branch", "expected_base_branch", "declared_files", "declared_scoped_tests", "status"],
      "properties": {
        "slice_id": { "type": "string", "minLength": 1 },
        "marker_id": { "type": "string", "minLength": 1 },
        "source_marker_ids": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "source_marker_checkpoints": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "route": { "type": "string", "enum": ["marker_split", "hazard_collapsed"] },
        "marker_split_evidence": { "type": "string", "minLength": 1 },
        "review_order": { "type": "integer", "minimum": 1 },
        "expected_branch": { "type": "string", "minLength": 1 },
        "expected_base_branch": { "type": "string", "minLength": 1 },
        "head_sha": { "type": ["string", "null"] },
        "declared_files": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "declared_scoped_tests": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "scoped_verification": { "$ref": "#/definitions/scoped_verification" },
        "emission_mapping": { "$ref": "#/definitions/emission_mapping" },
        "warnings": {
          "type": "array",
          "items": { "$ref": "#/definitions/warning" }
        },
        "pr": { "$ref": "#/definitions/pr" },
        "status": { "type": "string", "enum": ["pending", "branch_created", "verified", "pr_opened", "merged", "closed", "failed"] },
        "last_error": { "$ref": "#/definitions/failure" }
      },
      "additionalProperties": false
    },
    "scoped_verification": {
      "type": "object",
      "required": ["commands"],
      "properties": {
        "commands": {
          "type": "array",
          "items": { "$ref": "#/definitions/command_record" }
        }
      },
      "additionalProperties": false
    },
    "command_record": {
      "type": "object",
      "required": ["command", "gate_type", "reason", "required", "evidence_path", "exit_status", "started_at", "finished_at"],
      "properties": {
        "command": { "type": "string", "minLength": 1 },
        "gate_type": { "type": "string", "minLength": 1 },
        "reason": { "type": "string", "minLength": 1 },
        "required": { "type": "boolean" },
        "evidence_path": { "type": "string", "minLength": 1 },
        "exit_status": { "type": "integer" },
        "started_at": { "type": "string" },
        "finished_at": { "type": "string" },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" }
      },
      "additionalProperties": false
    },
    "pr": {
      "type": "object",
      "properties": {
        "number": { "type": "integer", "minimum": 1 },
        "url": { "type": "string", "minLength": 1 },
        "state": { "type": "string" },
        "base_ref": { "type": "string" },
        "head_ref": { "type": "string" },
        "head_sha": { "type": "string" },
        "merged_sha": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "emission_mapping": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["pending", "marker_split", "emitted", "hazard_collapsed"] },
        "packet_path": { "type": "string" },
        "source_marker_ids": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "pr_number": { "type": ["integer", "null"], "minimum": 1 },
        "pr_url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "warning": {
      "type": "object",
      "required": ["code", "severity", "message", "source", "details"],
      "properties": {
        "code": { "type": "string", "minLength": 1 },
        "severity": { "type": "string", "enum": ["info", "warning", "error"] },
        "message": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "details": { "type": "object" }
      },
      "additionalProperties": false
    },
    "failure": {
      "type": "object",
      "required": ["slice_id", "failed_at", "phase", "command", "exit_status", "evidence_path"],
      "properties": {
        "slice_id": { "type": "string", "minLength": 1 },
        "failed_at": { "type": "string" },
        "phase": { "type": "string", "minLength": 1 },
        "command": { "type": "string", "minLength": 1 },
        "exit_status": { "type": "integer" },
        "evidence_path": { "type": "string", "minLength": 1 },
        "stdout_tail": { "type": "string" },
        "stderr_tail": { "type": "string" },
        "head_sha": { "type": ["string", "null"] },
        "declared_tests": {
          "type": "array",
          "items": { "type": "string" }
        },
        "retry_policy": { "type": "string" }
      },
      "additionalProperties": false
    }
  }
}
