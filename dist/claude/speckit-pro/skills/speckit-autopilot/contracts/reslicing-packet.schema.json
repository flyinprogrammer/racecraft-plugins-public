{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft-lab/racecraft-plugins-public/prsg-010/reslicing-packet.schema.json",
  "title": "Final reviewability re-slicing packet",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "feature",
    "diff",
    "gate",
    "exceptions",
    "blocked_operations",
    "no_pr_assertions",
    "sizing",
    "layer_plan",
    "handoff",
    "suggested_slice_boundaries",
    "operator_steps",
    "resume"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "final_reviewability_reslicing_packet" },
    "feature": {
      "type": "object",
      "additionalProperties": false,
      "required": ["branch", "feature_dir", "spec_id", "title"],
      "properties": {
        "branch": { "type": "string", "minLength": 1 },
        "feature_dir": { "type": "string", "pattern": "^specs/" },
        "spec_id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "diff": {
      "type": "object",
      "additionalProperties": true,
      "required": ["base_ref", "head_ref", "changed_files"],
      "properties": {
        "base_ref": { "type": "string", "minLength": 1 },
        "head_ref": { "type": "string", "minLength": 1 },
        "changed_files": { "type": "integer", "minimum": 0 }
      }
    },
    "gate": {
      "type": "object",
      "additionalProperties": true,
      "required": ["status", "reason", "metrics"],
      "properties": {
        "status": { "type": "string", "enum": ["block"] },
        "reason": { "type": "string", "minLength": 1 },
        "metrics": { "type": "object", "additionalProperties": true }
      }
    },
    "exceptions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["accepted", "rejected"],
      "properties": {
        "accepted": {
          "type": "array",
          "items": { "$ref": "#/$defs/exceptionEvidence" }
        },
        "rejected": {
          "type": "array",
          "items": { "$ref": "#/$defs/exceptionEvidence" }
        }
      }
    },
    "blocked_operations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["pr-body-generation", "single-pr-create", "multi-pr-emission"]
      },
      "minItems": 3,
      "allOf": [
        { "contains": { "const": "pr-body-generation" } },
        { "contains": { "const": "single-pr-create" } },
        { "contains": { "const": "multi-pr-emission" } }
      ],
      "uniqueItems": true
    },
    "no_pr_assertions": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pr_created", "pr", "pr_body_generated", "single_pr_create_invoked", "gh_pr_create_invoked", "multi_pr_emission_invoked"],
      "properties": {
        "pr_created": { "const": false },
        "pr": { "type": "null" },
        "pr_body_generated": { "const": false },
        "single_pr_create_invoked": { "const": false },
        "gh_pr_create_invoked": { "const": false },
        "multi_pr_emission_invoked": { "const": false }
      }
    },
    "sizing": {
      "type": "object",
      "additionalProperties": true,
      "required": ["source", "summary", "route", "thresholds"],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "route": {
          "type": "string",
          "enum": [
            "split-PR",
            "one-navigable-PR",
            "single-atomic-PR",
            "out-of-scope",
            "branch-by-abstraction"
          ]
        },
        "thresholds": { "type": "object", "additionalProperties": true }
      }
    },
    "layer_plan": {
      "type": "object",
      "additionalProperties": true,
      "required": ["available", "status", "path", "slice_count"],
      "properties": {
        "available": { "type": "boolean" },
        "status": {
          "type": "string",
          "enum": ["available", "missing", "invalid", "needs-regeneration"]
        },
        "path": { "type": ["string", "null"] },
        "slice_count": { "type": "integer", "minimum": 0 }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tool",
        "command_template",
        "required_inputs",
        "layer_plan_path",
        "state_path",
        "full_verification_evidence_path",
        "changed_files_path"
      ],
      "properties": {
        "tool": { "const": "multi-pr-emission.sh" },
        "command_template": { "type": "string", "minLength": 1 },
        "required_inputs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "layer_plan_path": { "type": "string", "minLength": 1 },
        "state_path": { "type": "string", "minLength": 1 },
        "full_verification_evidence_path": { "type": "string", "minLength": 1 },
        "changed_files_path": { "type": "string", "minLength": 1 }
      }
    },
    "suggested_slice_boundaries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "rationale", "paths"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "title": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string", "minLength": 1 },
          "paths": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "operator_steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["order", "phase", "action", "command", "required_paths", "when", "expected_result"],
        "properties": {
          "order": { "type": "integer", "minimum": 1 },
          "phase": {
            "type": "string",
            "enum": ["prsg-007-routing", "prsg-008-layer-planning", "prsg-009-multi-pr-emission"]
          },
          "action": { "type": "string", "minLength": 1 },
          "command": { "type": "string", "minLength": 1 },
          "required_paths": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "when": { "type": "string", "minLength": 1 },
          "expected_result": { "type": "string", "minLength": 1 }
        }
      }
    },
    "resume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "next_action", "operator_message", "resume_from", "blocked_until"],
      "properties": {
        "status": { "const": "reslicing_required" },
        "next_action": { "type": "string", "minLength": 1 },
        "operator_message": { "type": "string", "minLength": 1 },
        "resume_from": {
          "type": "string",
          "enum": ["prsg-007-routing", "prsg-008-layer-planning", "prsg-009-multi-pr-emission"]
        },
        "blocked_until": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "exceptionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line", "class", "provenance", "branch_added", "honored", "reason"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "class": {
          "type": ["string", "null"],
          "enum": ["refactor", "infra", "upgrade", null]
        },
        "provenance": {
          "type": "string",
          "enum": ["contract", "generated", "process", "template", "pr-description", "commit-message", "code-fence", "unknown"]
        },
        "branch_added": { "type": "boolean" },
        "honored": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
