{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PRSG-009 restack output",
  "type": "object",
  "required": ["dry_run", "status", "exit_code", "base", "remote", "scope_preserved", "gh_stack", "recovery_evidence", "operations"],
  "properties": {
    "dry_run": { "type": "boolean" },
    "status": {
      "type": "string",
      "enum": ["success", "conflicts", "input_error", "dirty_worktree", "git_gh_failure"]
    },
    "exit_code": { "type": "integer" },
    "base": { "type": "string", "minLength": 1 },
    "remote": { "type": "string", "minLength": 1 },
    "start_after": { "type": ["string", "null"] },
    "scope_preserved": { "type": "boolean" },
    "gh_stack": {
      "type": "object",
      "required": ["available", "inspected", "mutating"],
      "properties": {
        "available": { "type": "boolean" },
        "inspected": { "type": "boolean" },
        "mutating": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "recovery_evidence": {
      "type": ["object", "null"],
      "properties": {
        "retry_policy": { "type": "string" },
        "failed_operation": {
          "type": ["object", "null"]
        },
        "evidence_path": {
          "type": ["string", "null"]
        }
      },
      "additionalProperties": false
    },
    "operations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slice_id", "branch", "old_base", "new_base", "action", "applied", "result"],
        "properties": {
          "slice_id": { "type": "string", "minLength": 1 },
          "branch": { "type": "string", "minLength": 1 },
          "old_base": { "type": "string", "minLength": 1 },
          "new_base": { "type": "string", "minLength": 1 },
          "action": { "type": "string", "enum": ["rebase", "retarget", "skip"] },
          "applied": { "type": "boolean" },
          "result": { "type": "string", "minLength": 1 },
          "pr_number": { "type": ["integer", "null"], "minimum": 1 },
          "declared_files": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "success" } },
        "required": ["status"]
      },
      "then": { "properties": { "exit_code": { "const": 0 } } }
    },
    {
      "if": {
        "properties": { "status": { "const": "conflicts" } },
        "required": ["status"]
      },
      "then": { "properties": { "exit_code": { "const": 1 } } }
    },
    {
      "if": {
        "properties": { "status": { "const": "input_error" } },
        "required": ["status"]
      },
      "then": { "properties": { "exit_code": { "const": 2 } } }
    },
    {
      "if": {
        "properties": { "status": { "const": "dirty_worktree" } },
        "required": ["status"]
      },
      "then": { "properties": { "exit_code": { "const": 3 } } }
    },
    {
      "if": {
        "properties": { "status": { "const": "git_gh_failure" } },
        "required": ["status"]
      },
      "then": { "properties": { "exit_code": { "const": 4 } } }
    }
  ],
  "additionalProperties": false
}
