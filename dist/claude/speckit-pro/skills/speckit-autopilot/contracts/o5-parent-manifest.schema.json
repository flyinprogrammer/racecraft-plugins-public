{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft-lab/racecraft-plugins-public/prsg-010/o5-parent-manifest.schema.json",
  "title": "O5 parent manifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "parent",
    "children",
    "sharedDesignConcept",
    "sharedRetrospective"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "o5_parent_manifest" },
    "parent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "branch", "path", "title"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]+-[0-9]+$" },
        "branch": { "type": "string", "pattern": "^[a-z0-9]+-[a-z0-9-]+$" },
        "path": {
          "type": "string",
          "pattern": "^specs/[^/]+$",
          "description": "Flat parent spec path; the topology validator must require this to equal specs/<parent.branch>."
        },
        "title": { "type": "string", "minLength": 1 }
      }
    },
    "children": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/child" }
    },
    "sharedDesignConcept": {
      "type": "string",
      "pattern": "^(docs/ai/specs/\\.process|specs/)"
    },
    "sharedRetrospective": {
      "type": ["string", "null"]
    },
    "declaredRollupStatus": {
      "type": ["string", "null"],
      "enum": ["invalid_topology", "blocked", "failed", "in_progress", "pending", "complete", null]
    }
  },
  "$defs": {
    "child": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "branch", "path", "title", "dependsOn"],
      "properties": {
        "id": { "type": "string", "pattern": "^[A-Z]+-[0-9]+[A-Z]$" },
        "branch": { "type": "string", "pattern": "^[a-z0-9]+-[0-9]+[a-z]-[a-z0-9-]+$" },
        "path": {
          "type": "string",
          "pattern": "^specs/[^/]+$",
          "description": "Flat child spec path; the topology validator must require this to equal specs/<child.branch>."
        },
        "title": { "type": "string", "minLength": 1 },
        "dependsOn": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[A-Z]+-[0-9]+[A-Z]$" },
          "uniqueItems": true
        }
      }
    }
  }
}
