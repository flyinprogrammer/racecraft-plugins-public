{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft-lab.github.io/racecraft-plugins-public/contracts/doc006-safe-aids.schema.json",
  "title": "DOC-006 Safe Interactive Selector and Validation Aids",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "selectorPaths",
    "manifestSources",
    "checkerComparisons",
    "diagramNodes",
    "firstRunCheckpoints",
    "handoffs"
  ],
  "properties": {
    "selectorPaths": {
      "type": "array",
      "minItems": 2,
      "items": {
        "$ref": "#/$defs/selectorPath"
      }
    },
    "manifestSources": {
      "type": "array",
      "minItems": 6,
      "items": {
        "$ref": "#/$defs/manifestSource"
      }
    },
    "checkerComparisons": {
      "type": "array",
      "minItems": 3,
      "items": {
        "$ref": "#/$defs/checkerComparison"
      }
    },
    "diagramNodes": {
      "type": "array",
      "minItems": 5,
      "items": {
        "$ref": "#/$defs/diagramNode"
      }
    },
    "firstRunCheckpoints": {
      "type": "array",
      "minItems": 9,
      "items": {
        "$ref": "#/$defs/firstRunCheckpoint"
      }
    },
    "handoffs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/handoff"
      }
    }
  },
  "$defs": {
    "selectorPath": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "scope",
        "label",
        "prerequisites",
        "commands",
        "successSignals",
        "nextLinks"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "platform": {
          "type": "string",
          "enum": [
            "claude-code",
            "codex"
          ]
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "prerequisites": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/commandGuidance"
          }
        },
        "successSignals": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "nextLinks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/link"
          }
        },
        "manifestRefs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "commandGuidance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "platform",
        "label",
        "command",
        "expectedSignal"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "platform": {
          "type": "string",
          "enum": [
            "claude-code",
            "codex"
          ]
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "command": {
          "type": "string",
          "minLength": 1
        },
        "expectedSignal": {
          "type": "string",
          "minLength": 1
        },
        "copyable": {
          "type": "boolean"
        }
      }
    },
    "manifestSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "path",
        "platform",
        "role"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "path": {
          "type": "string",
          "minLength": 1
        },
        "platform": {
          "type": "string",
          "enum": [
            "claude-code",
            "codex"
          ]
        },
        "role": {
          "type": "string",
          "enum": [
            "source-marketplace",
            "source-plugin",
            "dist-plugin"
          ]
        }
      }
    },
    "checkerComparison": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "rule",
        "leftSource",
        "rightSource",
        "state",
        "severity"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "rule": {
          "type": "string",
          "minLength": 1
        },
        "leftSource": {
          "type": "string",
          "minLength": 1
        },
        "rightSource": {
          "type": "string",
          "minLength": 1
        },
        "leftValue": {
          "type": "string"
        },
        "rightValue": {
          "type": "string"
        },
        "state": {
          "type": "string",
          "enum": [
            "pass",
            "mismatch",
            "unavailable"
          ]
        },
        "severity": {
          "type": "string",
          "enum": [
            "pass",
            "caution",
            "info"
          ]
        },
        "handoff": {
          "$ref": "#/$defs/link"
        }
      }
    },
    "diagramNode": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "kind",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "source-tree",
            "claude-dist",
            "codex-dist",
            "marketplace-entry",
            "codex-cache"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "inputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "outputs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "firstRunCheckpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "category",
        "description"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "platform-route",
            "prerequisite",
            "repository-state",
            "scaffold-output",
            "validation"
          ]
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "handoff": {
          "$ref": "#/$defs/link"
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "label",
        "href",
        "audience",
        "scope"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
        },
        "label": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        },
        "audience": {
          "type": "string",
          "enum": [
            "installer",
            "maintainer",
            "evaluator"
          ]
        },
        "scope": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "link": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "label",
        "href"
      ],
      "properties": {
        "label": {
          "type": "string",
          "minLength": 1
        },
        "href": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
