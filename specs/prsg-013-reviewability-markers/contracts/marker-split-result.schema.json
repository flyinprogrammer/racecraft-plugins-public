{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft.local/speckit-pro/marker-split-result.schema.json",
  "title": "Marker Split Final Backstop Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "outcome",
    "mode",
    "full_diff",
    "marker_plan",
    "emission",
    "warnings"
  ],
  "properties": {
    "status": {
      "enum": [
        "proceed",
        "stop"
      ]
    },
    "outcome": {
      "enum": [
        "marker_split",
        "single_pr",
        "correctness_stop"
      ]
    },
    "mode": {
      "const": "final"
    },
    "full_diff": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "reviewability_status"
      ],
      "properties": {
        "reviewability_status": {
          "enum": [
            "pass",
            "warn",
            "exception",
            "block"
          ]
        },
        "evidence_path": {
          "type": "string"
        }
      }
    },
    "marker_plan": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "valid",
        "fingerprint_matched"
      ],
      "properties": {
        "valid": {
          "type": "boolean"
        },
        "fingerprint_matched": {
          "type": "boolean"
        },
        "marker_count": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "emission": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "route",
        "markers"
      ],
      "properties": {
        "route": {
          "enum": [
            "marker_split",
            "hazard_collapsed",
            "single_pr"
          ]
        },
        "markers": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": true,
            "required": [
              "id",
              "review_order"
            ],
            "properties": {
              "id": {
                "type": "string",
                "minLength": 1
              },
              "review_order": {
                "type": "integer",
                "minimum": 1
              },
              "packet_path": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "code",
          "severity",
          "message",
          "source",
          "details"
        ],
        "properties": {
          "code": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "enum": [
              "info",
              "warning",
              "error"
            ]
          },
          "message": {
            "type": "string",
            "minLength": 1
          },
          "source": {
            "type": "string",
            "minLength": 1
          },
          "details": {
            "type": "object"
          }
        }
      }
    }
  }
}
