{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft-lab/racecraft-plugins-public/prsg-010/final-reviewability-gate-state.schema.json",
  "title": "Final reviewability gate state",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "kind",
    "status",
    "gate_result",
    "gate_reason",
    "metrics",
    "exception",
    "blocked_operations",
    "timestamp",
    "pr_created",
    "pr",
    "reslicing_packet_path"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "kind": { "const": "final_reviewability_gate" },
    "status": {
      "type": "string",
      "enum": ["pass", "warn", "exception", "block", "error"]
    },
    "gate_result": { "type": "string", "minLength": 1 },
    "gate_reason": { "type": "string", "minLength": 1 },
    "metrics": {
      "type": "object",
      "additionalProperties": true
    },
    "exception": {
      "type": "object",
      "additionalProperties": false,
      "required": ["honored", "class", "evidence"],
      "properties": {
        "honored": { "type": "boolean" },
        "class": {
          "type": ["string", "null"],
          "enum": ["refactor", "infra", "upgrade", null]
        },
        "evidence": {
          "type": "array",
          "items": { "$ref": "#/$defs/exceptionEvidence" }
        }
      }
    },
    "blocked_operations": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["pr-body-generation", "single-pr-create", "multi-pr-emission"]
      },
      "uniqueItems": true
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "pr_created": { "type": "boolean" },
    "pr": {
      "type": ["object", "null"],
      "additionalProperties": true
    },
    "reslicing_packet_path": {
      "type": ["string", "null"],
      "pattern": "^(specs|docs|\\.specify|speckit-pro)/"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "block" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "exception": {
            "type": "object",
            "properties": {
              "honored": { "const": false },
              "class": { "type": "null" }
            }
          },
          "blocked_operations": {
            "type": "array",
            "allOf": [
              { "contains": { "const": "pr-body-generation" } },
              { "contains": { "const": "single-pr-create" } },
              { "contains": { "const": "multi-pr-emission" } }
            ]
          },
          "pr_created": { "const": false },
          "pr": { "type": "null" },
          "reslicing_packet_path": { "type": "string" }
        },
        "required": ["reslicing_packet_path"]
      }
    },
    {
      "if": {
        "properties": { "status": { "enum": ["pass", "warn"] } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "reslicing_packet_path": { "type": "null" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "error" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "exception": {
            "type": "object",
            "properties": {
              "honored": { "const": false },
              "class": { "type": "null" }
            }
          },
          "pr_created": { "const": false },
          "pr": { "type": "null" },
          "reslicing_packet_path": { "type": "null" }
        }
      }
    },
    {
      "if": {
        "properties": { "status": { "const": "exception" } },
        "required": ["status"]
      },
      "then": {
        "properties": {
          "exception": {
            "type": "object",
            "required": ["honored", "class", "evidence"],
            "properties": {
              "honored": { "const": true },
              "class": {
                "type": "string",
                "enum": ["refactor", "infra", "upgrade"]
              },
              "evidence": {
                "type": "array",
                "minItems": 1,
                "items": { "$ref": "#/$defs/exceptionEvidence" }
              }
            }
          },
          "reslicing_packet_path": { "type": "null" }
        }
      }
    }
  ],
  "$defs": {
    "exceptionEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "line", "class", "provenance", "branch_added", "honored", "reason"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "line": { "type": "integer", "minimum": 1 },
        "class": {
          "type": ["string", "null"],
          "enum": ["refactor", "infra", "upgrade", null]
        },
        "provenance": {
          "type": "string",
          "enum": ["contract", "generated", "process", "template", "pr-description", "commit-message", "code-fence", "unknown"]
        },
        "branch_added": { "type": "boolean" },
        "honored": { "type": "boolean" },
        "reason": { "type": "string", "minLength": 1 }
      }
    }
  }
}
