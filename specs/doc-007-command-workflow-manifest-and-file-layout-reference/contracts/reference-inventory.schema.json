{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft-lab.github.io/racecraft-plugins-public/contracts/doc-007/reference-inventory.schema.json",
  "title": "DOC-007 Reference Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": ["pages"],
  "properties": {
    "pages": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": { "$ref": "#/$defs/page" }
    }
  },
  "$defs": {
    "page": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slug", "title", "publicPath", "outputPath", "records", "generatedNotice", "sources"],
      "properties": {
        "slug": {
          "enum": ["skills", "agents", "manifests", "hooks", "scripts", "tests", "source-vs-dist"]
        },
        "title": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "publicPath": {
          "type": "string",
          "pattern": "^/racecraft-plugins-public/reference/(skills|agents|manifests|hooks|scripts|tests|source-vs-dist)/$"
        },
        "outputPath": {
          "type": "string",
          "pattern": "^docs-site/src/content/docs/reference/(skills|agents|manifests|hooks|scripts|tests|source-vs-dist)\\.md$"
        },
        "generatedNotice": { "type": "string", "minLength": 1 },
        "sources": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/sourceCitation" }
        },
        "records": {
          "type": "array",
          "items": { "$ref": "#/$defs/record" }
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "heading", "purpose", "sourceFacts", "sources", "inferredNotes"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*$"
        },
        "heading": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "platformMapping": { "$ref": "#/$defs/platformMapping" },
        "classification": {
          "enum": ["source", "generated-payload", "test-only", "release-infrastructure", "documentation-infrastructure", "other"]
        },
        "sourceFacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceFact" }
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/$defs/sourceCitation" }
        },
        "inferredNotes": {
          "type": "array",
          "items": { "$ref": "#/$defs/inferredNote" }
        },
        "commandSkillReference": {
          "$ref": "#/$defs/commandSkillReference"
        },
        "manifestFieldSets": {
          "type": "array",
          "items": { "$ref": "#/$defs/manifestFieldSet" }
        }
      }
    },
    "platformMapping": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "concept": { "type": "string" },
        "claudeCode": { "type": "string" },
        "codex": { "type": "string" },
        "runtimeDifference": { "type": "string" }
      }
    },
    "commandSkillReference": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claudeInvocation", "codexInvocation", "purpose", "prerequisites", "expectedOutputArtifact", "sourceRefs"],
      "properties": {
        "claudeInvocation": { "type": "string", "minLength": 1 },
        "codexInvocation": { "type": "string", "minLength": 1 },
        "purpose": { "type": "string", "minLength": 1 },
        "prerequisites": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "expectedOutputArtifact": { "type": "string", "minLength": 1 },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "manifestFieldSet": {
      "type": "object",
      "additionalProperties": false,
      "required": ["runtime", "manifestKind", "requiredFields", "optionalFields", "sourceRefs"],
      "properties": {
        "runtime": {
          "enum": ["claude-code", "codex"]
        },
        "manifestKind": { "type": "string", "minLength": 1 },
        "requiredFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "optionalFields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sourceFact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "sourceRefs"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "sourceRefs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    },
    "sourceCitation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "githubUrl"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "fragment": { "type": "string" },
        "label": { "type": "string" },
        "githubUrl": {
          "type": "string",
          "pattern": "^https://github\\.com/racecraft-lab/racecraft-plugins-public/blob/main/.+"
        }
      }
    },
    "inferredNote": {
      "type": "object",
      "additionalProperties": false,
      "required": ["text", "basedOn"],
      "properties": {
        "text": { "type": "string", "minLength": 1 },
        "basedOn": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
