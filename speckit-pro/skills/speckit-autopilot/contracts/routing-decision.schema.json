{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://racecraft-lab/racecraft-plugins-public/prsg-010/routing-decision.schema.json",
  "title": "Atomicity router routing decision",
  "description": "Production routing-decision contract for atomicity-route.sh.",
  "oneOf": [
    {
      "title": "Success decision",
      "type": "object",
      "additionalProperties": false,
      "required": ["route", "releasable", "signals", "hints", "warnings"],
      "properties": {
        "route": {
          "type": "string",
          "enum": [
            "split-PR",
            "one-navigable-PR",
            "single-atomic-PR",
            "out-of-scope",
            "branch-by-abstraction"
          ]
        },
        "releasable": { "type": "boolean" },
        "signals": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "hard-atomic:exported-symbol-rename",
              "hard-atomic:global-version-pin",
              "hard-atomic:destructive-migration",
              "hard-atomic:mutual-exclusion-primitive",
              "hard-atomic:out-of-tree-contract-break",
              "releasability:destructive-migration",
              "releasability:concurrency",
              "change-shape:additive-multi-seam",
              "change-shape:modify-heavy",
              "context:flag-system:guarded-cutover",
              "context:release-cadence:release-held-cutover",
              "context:consumer-locality:all-in-tree",
              "context:consumer-locality:out-of-tree",
              "strategy:branch-by-abstraction"
            ]
          },
          "uniqueItems": true
        },
        "hints": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "hint:flag-system:weak",
              "hint:release-cadence:weak",
              "hint:consumer-locality:weak",
              "hint:contextual-probe:conflict"
            ]
          },
          "uniqueItems": true
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "destructive migration: a passing CI run does not prove this change is releasable (CI-green ≠ releasable)",
              "concurrency-sensitive change: a passing CI run does not prove this change is releasable (CI-green ≠ releasable)"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    {
      "title": "Error decision",
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": { "type": "string", "minLength": 1 }
      }
    }
  ]
}
